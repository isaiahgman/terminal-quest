{
  "name": "terminal-quest",
  "version": "0.0.0",
  "description": "A real-time terminal action-roguelike with Solo-Leveling progression.",
  "type": "module",
  "bin": {
    "terminal-quest": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "clean": "rimraf dist",
    "prebuild": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts eslint.config.mjs",
    "lint:fix": "eslint src scripts eslint.config.mjs --fix",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.{ts,mjs}\" \"*.{mjs,json}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.{ts,mjs}\" \"*.mjs\"",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "license": "MIT",
  "dependencies": {
    "rot-js": "^2.2.1",
    "terminal-kit": "^3.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/terminal-kit": "^2.5.7",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaiahgman/terminal-quest.git"
  },
  "keywords": [
    "roguelike",
    "terminal",
    "game",
    "cli",
    "ascii",
    "action"
  ]
}
