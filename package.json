{
  "name": "terminal-quest",
  "version": "0.0.0",
  "description": "A real-time terminal action-roguelike with Solo-Leveling progression.",
  "type": "module",
  "bin": {
    "terminal-quest": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
