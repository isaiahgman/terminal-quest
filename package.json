    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "rot-js": "^2.2.1",
    "terminal-kit": "^3.1.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/terminal-kit": "^2.5.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
